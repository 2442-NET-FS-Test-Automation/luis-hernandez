# Endpoint para restaurar el inventario

```csharp
app.MapPost("/inventory/reset",
    (LibraryDbContext db,
     ILogger<Program> logger) =>
{
    logger.LogInformation(
        "Iniciando restauración del inventario.");

    foreach (InventoryItem inv in db.Inventory)
    {
        switch (inv.Id)
        {
            case 1:
                inv.CurrentStock = 5;
                break;

            case 2:
                inv.CurrentStock = 3;
                break;

            case 3:
                inv.CurrentStock = 8;
                break;
        }
    }

    db.SaveChanges();

    logger.LogInformation(
        "Inventario restaurado correctamente.");

    return Results.Ok("stock reset");
});
```

