{
    using var db =
        _factory.CreateDbContext();

    _logger.LogInformation(
        "Procesando orden {OrderId}",
        orderId);

    await Task.Delay(50, ct);

    // Aquí se aplicaría la lógica
    // de actualización de inventario.
}
```

Cada orden obtiene su propio `DbContext`.

